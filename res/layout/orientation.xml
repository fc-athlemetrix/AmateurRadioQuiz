<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
xmlns:app="http://schemas.android.com/apk/res-auto"
xmlns:tools="http://schemas.android.com/tools"
android:id="@+id/orientationLayout"
android:layout_width="match_parent"
android:layout_height="match_parent"
android:orientation="vertical">




<TextView
    android:id="@+id/orientation"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="center_horizontal"
    android:background="#6789AB"
    android:gravity="center_horizontal"
    android:text="Orientation"
    android:textColor="#ffffff"
    android:textSize="25sp"
    app:layout_constraintBottom_toTopOf="@+id/orientationDialLayout"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintHorizontal_bias="0.1"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintVertical_bias="0.205" />


    <LinearLayout
        android:id="@+id/orientationDialLayout"
        android:layout_width="196dp"
        android:layout_height="209dp"

        android:layout_marginTop="40dp"
        android:background="@drawable/compassring"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/orientation">

        <ImageView
            android:id="@+id/pointer"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_weight="1"
            android:src="@drawable/pointer"></ImageView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/orientationDialLayout2"
        android:layout_width="196dp"
        android:layout_height="209dp"

        android:layout_marginTop="292dp"
        android:background="@drawable/compassring"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.479"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/orientation">

        <ImageView
            android:id="@+id/pointer2"
            android:layout_width="match_parent"
            android:layout_height="197dp"
            android:layout_weight="1"
            android:src="@drawable/pointerhalf"></ImageView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/linearLayout2"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginTop="148dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="@+id/orientationLayout"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/orientationDialLayout2">

        <Button
            android:id="@+id/words"
            android:layout_width="129dp"
            android:layout_height="match_parent"
            android:layout_gravity="left"
            android:text="Telemetry" />

        <Button
            android:id="@+id/settings"
            android:layout_width="146dp"
            android:layout_height="match_parent"
            android:layout_gravity="center_horizontal"
            android:text="Settings" />

        <Button
            android:id="@+id/info"
            android:layout_width="134dp"
            android:layout_height="match_parent"
            android:layout_gravity="right"
            android:text="INFO" />

    </LinearLayout>

    <TextView
        android:id="@+id/orientationText"
        android:layout_width="121dp"
        android:layout_height="21dp"
        android:layout_marginStart="268dp"
        android:text="Orientation"
        app:layout_constraintStart_toStartOf="parent"
        tools:layout_editor_absoluteY="602dp" />

    <TextView
        android:id="@+id/pitch"
        android:layout_width="118dp"
        android:layout_height="19dp"
        android:layout_marginStart="128dp"
        android:layout_marginEnd="165dp"
        android:layout_marginBottom="68dp"
        android:text="Pitch: 0 deg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/roll"
        android:layout_width="116dp"
        android:layout_height="19dp"
        android:layout_marginStart="276dp"
        android:layout_marginEnd="19dp"
        android:layout_marginBottom="68dp"
        android:text="Roll: 0 deg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/yaw"
        android:layout_width="116dp"
        android:layout_height="19dp"
        android:layout_marginStart="12dp"
        android:layout_marginBottom="68dp"
        android:text="Yaw: 0 deg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />


</androidx.constraintlayout.widget.ConstraintLayout>